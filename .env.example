# Supabase Public Keys (Used on Client & Server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Admin Secret Key (USED ONLY IN IMPORT SCRIPT - NEVER EXPOSE TO FRONTEND)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# GitHub Access Token (Used to bypass REST API rate limiting during import script run)
GITHUB_TOKEN=ghp_yourpersonalaccesstokenhere

# GitHub Import Repository Configuration
GITHUB_REPO=owner/repo
GITHUB_PATHS=assets/logos,assets/flyers,assets/instagram

# Social Profiles Configuration
NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/yourusername
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/yourusername
NEXT_PUBLIC_CONTACT_EMAIL=hello@yourdomain.com

# Form Service submission Endpoint (Optional - e.g. Formspree/Web3Forms)
# Leave blank to fall back to simulated successful contact submit
NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=
